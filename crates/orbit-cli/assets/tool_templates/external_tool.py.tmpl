#!/usr/bin/env python3

"""Starter Orbit external tool.

Orbit sends JSON input on stdin and expects JSON output on stdout.
This starter demonstrates how to read the ORBIT_TOOL_* context variables.
"""

import json
import os
import sys


def _split_csv(name: str) -> list[str]:
    raw = os.environ.get(name, "")
    return [item for item in (part.strip() for part in raw.split(",")) if item]


def main() -> int:
    payload = json.load(sys.stdin)

    subject = payload.get("name") or "Orbit"
    include_context = bool(payload.get("include_context", False))

    response = {
        "ok": True,
        "tool": os.environ.get("ORBIT_TOOL_NAME", "__ORBIT_TOOL_NAME__"),
        "message": f"Hello, {subject}!",
    }

    if include_context:
        response["context"] = {
            "cwd": os.environ.get("ORBIT_TOOL_CWD"),
            "workspace_root": os.environ.get("ORBIT_TOOL_WORKSPACE_ROOT"),
            "agent_name": os.environ.get("ORBIT_TOOL_AGENT_NAME"),
            "model_name": os.environ.get("ORBIT_TOOL_MODEL_NAME"),
            "allowed_tools": _split_csv("ORBIT_TOOL_ALLOWED_TOOLS"),
            "proc_allowed_programs": _split_csv("ORBIT_TOOL_PROC_ALLOWED_PROGRAMS"),
        }

    json.dump(response, sys.stdout)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
