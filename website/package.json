{
  "name": "orbit-website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:design": "node ./scripts/sync-design-docs.mjs",
    "sync:benchmarks": "node ./scripts/sync-benchmarks.mjs",
    "predev": "npm run sync:design && npm run sync:benchmarks",
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "prebuild": "npm run sync:design && npm run sync:benchmarks",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "prepreview": "npm run sync:design && npm run sync:benchmarks",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "precheck": "npm run sync:design && npm run sync:benchmarks",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.4",
    "astro": "^6.1.9"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "yaml": "2.8.3"
  }
}
