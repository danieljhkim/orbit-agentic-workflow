---
import Default from '@astrojs/starlight/components/Footer.astro';
---

<Default><slot /></Default>

<footer class="orbit-footer">
  <div class="orbit-footer-inner">
    <div class="orbit-footer-brand-container" style="display: flex; align-items: baseline; gap: 0.75rem;">
      <span class="orbit-footer-brand">Orbit</span>
      <span class="orbit-footer-signature" style="font-family: var(--sl-font-mono); font-size: 0.75rem; color: var(--sl-color-accent);">designed by gemini</span>
    </div>
    <nav aria-label="Footer">
      <a href="https://github.com/danieljhkim/orbit">Source</a>
      <a href="https://github.com/danieljhkim/orbit/blob/main/LICENSE.md">License</a>
      <a href="https://github.com/danieljhkim/orbit/issues">Issues</a>
    </nav>
  </div>
</footer>
